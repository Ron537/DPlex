{
  "name": "dplex",
  "version": "0.19.0",
  "description": "A terminal multiplexer built for AI-assisted development. Manage multiple AI CLI sessions (Copilot, Claude, and more) alongside regular terminals in one window.",
  "main": "./out/main/index.js",
  "author": {
    "name": "Ron Borysowski",
    "email": "roni537@gmail.com",
    "url": "https://github.com/Ron537"
  },
  "license": "MIT",
  "homepage": "https://github.com/Ron537/DPlex#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ron537/DPlex.git"
  },
  "bugs": {
    "url": "https://github.com/Ron537/DPlex/issues"
  },
  "keywords": [
    "terminal",
    "multiplexer",
    "electron",
    "ai",
    "copilot",
    "claude",
    "claude-code",
    "ai-cli",
    "developer-tools",
    "productivity"
  ],
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "npm run test:unit",
    "test:unit": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:e2e": "npm run build && node ./scripts/run-playwright.mjs e2e",
    "test:monkey": "npm run build && node ./scripts/run-playwright.mjs monkey",
    "test:all": "npm run test:unit && npm run test:e2e && npm run test:monkey",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && node scripts/detach-stale-dmg.js && CUSTOM_DMGBUILD_PATH=scripts/dmgbuild-wrapper.sh electron-builder --mac",
    "build:mac:ci": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "demo:screenshots": "npm run build && tsx scripts/screenshots.ts",
    "demo:gif": "npm run build && tsx scripts/demo-gif.ts",
    "site:build": "node scripts/build-site.mjs",
    "site:serve": "npx --yes serve@14 -l 8080 _site",
    "site:dev": "npm run site:build && npm run site:serve"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/diff": "^7.0.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "allotment": "^1.20.5",
    "diff": "^9.0.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "ignore": "^7.0.5",
    "lucide-react": "^1.14.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "electron": "^42.0.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "ffmpeg-static": "^5.3.0",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^7.2.6",
    "vitest": "^4.1.4"
  }
}
